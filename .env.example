# LiveKit credentials (get from https://cloud.livekit.io)
LIVEKIT_URL=your-livekit-url
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# Sarvam AI API key (STT and TTS)
SARVAM_API_KEY=your-sarvam-api-key
SARVAM_STT_LANGUAGE=en-IN

# OpenRouter API key (main LLM)
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_LLM_MODEL=openai/gpt-4o-mini
OPENROUTER_VISION_MODEL=openai/gpt-4o-mini
# Lower = more deterministic, usually faster perceived response.
OPENROUTER_TEMPERATURE=0.2
# Keep responses short for voice smoothness.
OPENROUTER_MAX_TOKENS=100
OPENROUTER_TOP_P=0.85
# Cooldown window after OpenRouter quota/rate-limit errors before retrying provider.
OPENROUTER_QUOTA_COOLDOWN_SECONDS=60
# Max read wait for model response chunks before fast-fail fallback.
OPENROUTER_TIMEOUT_SECONDS=4
# 1 = fallback quickly on any provider error, 0 = fallback only on quota/rate errors.
OPENROUTER_FALLBACK_ON_ANY_ERROR=1
# Voice turn endpointing delay in seconds (clamped in code for stability).
ENDPOINTING_DELAY_SECONDS=0.025
# Optional OpenRouter routing/analytics headers.
OPENROUTER_HTTP_REFERER=
OPENROUTER_X_TITLE=Friday Tony Stark Demo

# Local PC automation controls (OFF by default for safety).
FRIDAY_ENABLE_PC_AUTOMATION=0
FRIDAY_ENABLE_SHELL=0
# Semicolon-separated allowed root folders for read/write/search tools.
FRIDAY_ALLOWED_ROOTS=
# Comma-separated allowlist for launch_app.
FRIDAY_ALLOWED_APPS=notepad,explorer,chrome,msedge,code,cmd,powershell

# Supabase configuration for ticketing system
SUPABASE_URL=your-supabase-url
SUPABASE_API_KEY=your-supabase-api-key